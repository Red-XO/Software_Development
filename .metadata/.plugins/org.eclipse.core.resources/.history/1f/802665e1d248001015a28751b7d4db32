package Day_6;
public class Task_3 {
	int arr[] = new int[5];
	int rear;
	int front;
	public void queue() {
		rear=-1;
		front=-1;
	}
	public void en_queue(int num) {
		if(rear==4) {
			System.out.println("Queue Spreadout");
		}
		else {
			arr[++rear]=num;
		}
	}
	public void de_queue() {
		if(front==4) {
			System.out.println("Empty Queue");
		}
		else {
			arr[++front]=0;
		}
	}
}

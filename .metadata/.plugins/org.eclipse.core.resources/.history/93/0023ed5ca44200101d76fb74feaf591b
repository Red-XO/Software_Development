package Day_2;

public class Task_1 {

	public static void main(String[] args) {
	int arr[]= {4,2,10,7,5,3,8};
	int start=arr[0];
	int end = arr[arr.length-1];
	for(int i=start;i<arr.length-1;i++) {
		for(int j=end;j<arr.length-1;j--) {
			while(start<end) {
				int temp = end;
				end = start;
				start = temp;
			}
		}
	}
	for(int a=0;a<arr.length-1;a++) {
		System.out.println(arr[a]);
	}
	}

}

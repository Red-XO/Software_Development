package Day_2;

public class Task_1 {

	public static void main(String[] args) {
	int arr[] = {4,2,10,7,5,3,8};
	int start=arr[0];
	int end=arr[arr.length-1];
	for(int i=0;i<arr.length-1;i++) {
		if(arr[i]<start) {
			arr[i]=arr[i-1];
		}
		if(arr[i]>end) {
			arr[arr.length-1]=arr[i];
		}
		for(int a=0;i<arr.length-1;i++) {
			System.out.println(arr[a]);
		}
	}
	}

}

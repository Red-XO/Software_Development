	public void push(int[] arr,int num,int val) {
		int top = -1;
		for(int i=0; i<arr.length;i++) {
			if(top==4) {
				System.out.println("Stack Overflow");
			}
			else {
				arr[++top]=val;
			}	
	}
	}

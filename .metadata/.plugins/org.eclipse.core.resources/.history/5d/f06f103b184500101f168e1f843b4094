package Day_3;
	class Insertion{
		Node head;
		public void insert(int data,int pos) {
			Node newNode = new Node(data);
			if(head == null) {
				head = newNode;
			}
			else {
				Node temp = newNode;
				while(temp.next != null) {
					temp = temp.next;
				}
				temp.next = newNode;
			}
		}
		public void display() {
			Node temp = head;
			while(temp != null){
				 System.out.print(temp.data + " -> ");
		            temp = temp.next;	
			}
			System.out.print("null");
		}
	}

